<Window x:Class="Callen.Windows.Forms.AddArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AddArchiveWindow"
        Height="600"
        Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="dialogCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.CloseWindow}"
                                           Tint="#FF2E3136"
                                           Width="{StaticResource dialogCloseIconSize}"
                                           Height="{StaticResource dialogCloseIconSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- UPDATED: full-window overlay (no fixed size) -->
        <Border Name="closeBorder"
                Background="Black"
                Opacity="0.1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="600">
                <Canvas Height="150"
                        Width="220"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                    <Border Height="150" Width="220"
                            Canvas.Left="0" Canvas.Top="0"
                            Background="{DynamicResource lightestHighLight}"
                            CornerRadius="3,3,3,3" />

                    <Button Width="25" Height="25"
                            Panel.ZIndex="3"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource dialogCloseButtonStyle}"
                            Canvas.Left="195"
                            Canvas.Top="0" />

                    <!-- Header title in centered container -->
                    <Grid Width="220"
                          Height="30"
                          Canvas.Left="0"
                          Canvas.Top="6"
                          Panel.ZIndex="2">
                        <Label Name="wind_name"
                               Content="Adicionar Pasta/Tema"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Style="{DynamicResource menuFont}"
                               FontSize="13.5"
                               Foreground="{DynamicResource highLight}" />
                    </Grid>

                    <Label Content="Pasta"
                           Canvas.Left="12"
                           Canvas.Top="46"
                           Style="{DynamicResource formLabel}"
                           Width="50" />
                    <TextBox Name="folder_box"
                             Width="140"
                             Canvas.Left="67"
                             Canvas.Top="45"
                             Height="26"
                             Style="{DynamicResource formTextBox}" />

                    <Label Content="Tema"
                           Canvas.Left="12"
                           Canvas.Top="77"
                           Style="{DynamicResource formLabel}"
                           Width="50" />
                    <TextBox Name="theme_box"
                             Width="140"
                             Canvas.Left="67"
                             Canvas.Top="76"
                             Height="26"
                             Style="{DynamicResource formTextBox}" />

                    <Button Name="btn_add_folder"
                            Click="btn_add_folder_Click"
                            Content="Submeter"
                            Canvas.Left="79"
                            Canvas.Top="120"
                            Width="62" />
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>






