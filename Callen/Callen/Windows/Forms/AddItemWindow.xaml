<Window x:Class="Callen.Windows.Forms.AddItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Name="w1"
        Title="AddItemWindow"
        Height="600"
        Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="dialogCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.CloseWindow}"
                                           Tint="#FF2E3136"
                                           Width="{StaticResource dialogCloseIconSize}"
                                           Height="{StaticResource dialogCloseIconSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="dialogIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{TemplateBinding Tag}"
                                           Width="{StaticResource dialogIconSize}"
                                           Height="{StaticResource dialogIconSize}"
                                           Tint="#FF2E3136"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Full-window overlay -->
        <Border Name="closeBorder"
                Background="Black"
                Opacity="0.1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="600">
                <Canvas Width="500"
                        Height="300"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Border Height="300" Width="500"
                        Canvas.Left="0" Canvas.Top="0"
                        Background="{DynamicResource lightestHighLight}"
                        CornerRadius="3,3,3,3" />

                <Button Width="25" Height="25"
                        Panel.ZIndex="3"
                        x:Name="btn_close"
                        Click="btn_close_Click"
                        Style="{StaticResource dialogCloseButtonStyle}"
                        Canvas.Left="475"
                        Canvas.Top="0" />

                <Label Content="Nome" Canvas.Left="9" Canvas.Top="35"
                       Style="{DynamicResource formLabel}" Width="77" Height="26" />
                <TextBox Name="name_box" Width="150" Canvas.Left="89" Canvas.Top="34" Height="26"
                         Style="{DynamicResource formTextBox}" />

                <Label Content="Ano" Canvas.Left="9" Canvas.Top="71"
                       Style="{DynamicResource formLabel}" Width="77" Height="26" />
                <TextBox Name="year_box" Width="150" Canvas.Left="89" Canvas.Top="70" Height="26"
                         Style="{DynamicResource formTextBox}" />

                <Label Content="Coleção" Canvas.Left="9" Canvas.Top="107"
                       Style="{DynamicResource formLabel}" Width="77" Height="26" />
                <TextBox Name="collec_box" Width="150" Canvas.Left="89" Canvas.Top="106" Height="26"
                         Style="{DynamicResource formTextBox}" />

                <Label Content="Matriz" Canvas.Left="9" Canvas.Top="143"
                       Style="{DynamicResource formLabel}" Width="77" Height="26" />
                <TextBox Name="other_box" Width="150" Canvas.Left="89" Canvas.Top="142" Height="26"
                         Style="{DynamicResource formTextBox}" />

                <Label Content="Descrição" Canvas.Left="259" Canvas.Top="107"
                       Style="{DynamicResource formLabel}" Width="77" Height="26" />
                <TextBox Name="desc_box" Width="228"
                         VerticalContentAlignment="Top"
                         Canvas.Left="259" Canvas.Top="137"
                         Height="130"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Style="{DynamicResource formTextBox}" />

                <Label Content="Pasta" Canvas.Left="259" Canvas.Top="35"
                       Style="{DynamicResource formLabel}" Width="77" Height="26" />
                <ComboBox Name="combo_folder" Width="130" Canvas.Left="341" Canvas.Top="35" Height="26"
                          SelectionChanged="combo_folder_SelectionChanged" />

                <Button Name="btn_manage_archive"
                        Click="btn_manage_archive_Click"
                        Tag="{StaticResource Icon.BinderFile}"
                        Width="29"
                        Height="26"
                        Canvas.Top="35"
                        Canvas.Left="471"
                        Style="{StaticResource dialogIconButtonStyle}" />

                <Label Content="Tema" Canvas.Left="258" Canvas.Top="71"
                       Style="{DynamicResource formLabel}" />
                <ComboBox Name="combo_theme" Width="130" Canvas.Left="341" Canvas.Top="71" Height="26"
                          IsEnabled="False" />

                <Label Content="Foto" Canvas.Left="9" Canvas.Top="179"
                       Style="{DynamicResource formLabel}" Width="77" Height="26"/>

                <Border Name="img_border"
                        Visibility="Hidden"
                        Canvas.Left="89"
                        Canvas.Top="183"
                        Width="150"
                        Height="100"
                        Background="Transparent">
                    <Image Name="img"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <Button Width="77" Height="15"
                        x:Name="btn_upload"
                        Click="btn_upload_Click"
                        Tag="{StaticResource Icon.Upload}"
                        Canvas.Left="9"
                        Canvas.Top="214"
                        Style="{StaticResource dialogIconButtonStyle}" />

                <Button Name="btn_insert"
                        Click="btn_insert_Click"
                        Content="Inserir"
                        Canvas.Left="437"
                        Canvas.Top="272"
                        Width="50" />
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>







