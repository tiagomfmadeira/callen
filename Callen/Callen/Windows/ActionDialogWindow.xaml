<Window x:Class="Callen.Windows.ActionDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialog"
        Width="520"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border BorderThickness="1"
            Background="{DynamicResource lightestHighLight}"
            BorderBrush="Black"
            CornerRadius="10"
            Padding="18">
        <StackPanel HorizontalAlignment="Center">
            <Grid Width="455"
                  HorizontalAlignment="Center">
                <TextBlock Name="dialogTitle"
                           Margin="4,2,4,8"
                           FontWeight="ExtraBlack"
                           FontSize="19"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="445" />
            </Grid>
            <TextBlock Name="dialogContext"
                       Margin="4,0,4,6"
                       FontWeight="SemiBold"
                       FontSize="18"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="445"
                       Visibility="Collapsed" />
            <TextBlock Name="dialogMessage"
                       Margin="4,0,4,16"
                       FontSize="18"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="445" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Name="btn_cancel"
                        Width="118"
                        Height="38"
                        Margin="0,0,10,0"
                        FontSize="16"
                        Click="btn_cancel_Click"
                        Visibility="Collapsed" />
                <Button Name="btn_secondary"
                        Width="118"
                        Height="38"
                        Margin="0,0,10,0"
                        FontSize="16"
                        Click="btn_secondary_Click"
                        Visibility="Collapsed" />
                <Button Name="btn_primary"
                        Width="118"
                        Height="38"
                        FontSize="16"
                        Click="btn_primary_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

