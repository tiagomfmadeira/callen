<UserControl x:Class="Callen.Pages.proSearch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Callen.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="575" d:DesignWidth="800">
    <Grid Style="{StaticResource gridStyle}">
        <Grid.RowDefinitions>

            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Border BorderBrush="{DynamicResource darkestHighLight}" Style="{StaticResource simpleBorder}">
            <DataGrid Name="grdColec" Style="{DynamicResource dataGrid}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource darkestHighLight}"/>
                        <Setter Property="Foreground" Value="{DynamicResource lightestHighLight}"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.ItemContainerStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="Row_DoubleClick"/>
                    </Style>
                </DataGrid.ItemContainerStyle>
            </DataGrid>
        </Border>

        <Button HorizontalAlignment="Right" Click="formPage" Grid.Row="1" Margin="10,10,10,0" Style="{StaticResource addButton}"/>
    </Grid>
</UserControl>
