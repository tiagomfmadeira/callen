<UserControl x:Class="Callen.Pages.Search"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:Callen"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="575"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Thickness x:Key="SearchLabelMargin">3</Thickness>
        <Thickness x:Key="SearchFieldMargin">3</Thickness>

        <Style x:Key="SearchHeaderToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{StaticResource brushWatermarkBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource highLight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="headerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="headerBorder" Property="Background" Value="#FFC2C7CB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="headerBorder" Property="Background" Value="#FFC2C7CB" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="headerBorder" Property="Background" Value="#FFC2C7CB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchInputTextBoxStyle"
               TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="{StaticResource SearchFieldMargin}" />
            <Setter Property="Background" Value="#FFF4F5F6" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF2E3136" />
            <Setter Property="SelectionBrush" Value="#8FAEB2B7" />
            <Setter Property="CaretBrush" Value="{DynamicResource foreground}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="2,1,2,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="searchInputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="searchInputBorder" Property="Background" Value="#FFE6E9EB" />
                                <Setter TargetName="searchInputBorder" Property="BorderBrush" Value="#FF9EA3A8" />
                                <Setter TargetName="searchInputBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="searchInputBorder" Property="Background" Value="#FFEAEDEF" />
                                <Setter TargetName="searchInputBorder" Property="BorderBrush" Value="#FF777D83" />
                                <Setter TargetName="searchInputBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="searchInputBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchLabelTextStyle"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource advanceSearchFont}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="{StaticResource SearchLabelMargin}" />
        </Style>

        <Style x:Key="SearchBottomActionButton"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource bottomActionButton}">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="SearchBottomActionButtonLast"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource bottomActionButtonLast}">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="SearchBottomActionRow"
               TargetType="{x:Type Panel}"
               BasedOn="{StaticResource bottomActionRow}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="{StaticResource layoutSpacing3}" />
        </Style>

        <Style x:Key="SearchAdvanceFormStyle"
               TargetType="{x:Type Grid}"
               BasedOn="{StaticResource advanceSearchForm}">
            <Setter Property="Margin" Value="{StaticResource layoutSpacing3}" />
        </Style>

        <Style x:Key="SearchHeaderChevronStyle" TargetType="{x:Type Path}">
            <Setter Property="Data" Value="M 0 0 L 10 0 L 5 6" />
            <Setter Property="Fill" Value="{DynamicResource highLight}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True">
                    <Setter Property="Data" Value="M 0 6 L 10 6 L 5 0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="rootSearch"
          Style="{StaticResource gridStyle}"
          Margin="10,0,10,10"
          PreviewMouseDown="RootSearch_PreviewMouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <ToggleButton x:Name="advanceSearch"
                      Grid.Row="0"
                      Grid.Column="1"
                      Margin="0,0,0,6"
                      Height="32"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Cursor="Hand"
                      Style="{StaticResource SearchHeaderToggleStyle}">
            <Grid x:Name="searchHeaderBar">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>

                <ui:TintedIcon Grid.Column="0"
                               MaskSource="{StaticResource Icon.Search}"
                               Width="16"
                               Height="16"
                               Margin="10,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Tint="#FF252323"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                <TextBlock Grid.Column="1"
                           Margin="4,-1,0,0"
                           VerticalAlignment="Center"
                           Text="{DynamicResource Search.Header}"
                           FontSize="16"
                           Foreground="{StaticResource brushWatermarkForeground}" />

                <Path Grid.Column="2"
                      x:Name="searchHeaderChevron"
                      Width="10"
                      Height="6"
                      Margin="0,0,10,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Style="{StaticResource SearchHeaderChevronStyle}" />
            </Grid>
        </ToggleButton>

        <Border x:Name="advanceSearchPanel"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                Margin="0,42,0,0"
                Panel.ZIndex="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="{Binding ElementName=advanceSearch, Path=ActualWidth}"
                PreviewKeyDown="Border_PreviewKeyDown"
                Background="{StaticResource brushWatermarkBackground}"
                BorderBrush="{DynamicResource highLight}"
                Visibility="{Binding ElementName=advanceSearch, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Hidden}"
                Style="{StaticResource advanceSearchBorder}">
            <Grid Style="{StaticResource SearchAdvanceFormStyle}" TextElement.FontSize="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Text="{DynamicResource Search.Name}" Style="{StaticResource SearchLabelTextStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" Text="{DynamicResource Search.Id}" Style="{StaticResource SearchLabelTextStyle}" />

                <TextBox Name="name_box" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource SearchInputTextBoxStyle}" />
                <TextBox Name="id_box" Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Style="{StaticResource SearchInputTextBoxStyle}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{DynamicResource Search.Collection}" Style="{StaticResource SearchLabelTextStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Text="{DynamicResource Search.Folder}" Style="{StaticResource SearchLabelTextStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2" Text="{DynamicResource Search.Year}" Style="{StaticResource SearchLabelTextStyle}" />

                <TextBox Name="collec_box" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SearchInputTextBoxStyle}" />
                <TextBox Name="folder_box" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource SearchInputTextBoxStyle}" />
                <TextBox Name="year_box" Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="2" Style="{StaticResource SearchInputTextBoxStyle}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="{DynamicResource Search.Matrix}" Style="{StaticResource SearchLabelTextStyle}" />
                <TextBlock Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="3" Text="{DynamicResource Search.Theme}" Style="{StaticResource SearchLabelTextStyle}" />

                <TextBox Name="other_box" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource SearchInputTextBoxStyle}" />
                <TextBox Name="theme_box" Grid.Row="5" Grid.Column="3" Grid.ColumnSpan="3" Style="{StaticResource SearchInputTextBoxStyle}" />

                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="{DynamicResource Search.Description}" Style="{StaticResource SearchLabelTextStyle}" />
                <TextBox Name="desc_box"
                         Grid.Row="7"
                         Grid.Column="0"
                         Grid.ColumnSpan="6"
                         Margin="{StaticResource SearchFieldMargin}"
                         Height="92"
                         MinHeight="92"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         Style="{StaticResource SearchInputTextBoxStyle}"
                         VerticalContentAlignment="Top" />

                <StackPanel Grid.Row="8"
                            Grid.Column="0"
                            Grid.ColumnSpan="6"
                            Orientation="Horizontal"
                            Style="{StaticResource SearchBottomActionRow}">
                    <Button Name="btn_adv_clear"
                            Click="btn_adv_clear_Click"
                            Style="{StaticResource SearchBottomActionButton}"
                            Content="{DynamicResource Search.Clear}" />

                    <Button Name="btn_adv_search"
                            Click="btn_adv_search_Click"
                            Style="{StaticResource SearchBottomActionButtonLast}"
                            Content="{DynamicResource Search.Search}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                BorderBrush="{DynamicResource highLight}"
                BorderThickness="1"
                CornerRadius="2">
            <Grid x:Name="Search_mode" />
        </Border>
    </Grid>
</UserControl>
