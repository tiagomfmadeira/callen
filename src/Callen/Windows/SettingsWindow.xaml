<Window x:Class="Callen.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SettingsWindow"
        Height="600"
        Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="settingsCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.CloseWindow}"
                                           Tint="#FF2E3136"
                                           Width="{StaticResource dialogCloseIconSize}"
                                           Height="{StaticResource dialogCloseIconSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="settingsFolderPickerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.OpenFolder}"
                                           Width="{StaticResource dialogIconSize}"
                                           Height="{StaticResource dialogIconSize}"
                                           Tint="#FF2E3136" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Name="closeBorder"
                Background="Black"
                Opacity="0.16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="600">
                <Canvas Width="479"
                        Height="169"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <Border Height="169" Width="479" Canvas.Left="0" Canvas.Top="0"
                            Background="{DynamicResource lightestHighLight}" CornerRadius="3,3,3,3" />

                    <Button Width="25" Height="25"
                            Panel.ZIndex="3"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource settingsCloseButtonStyle}"
                            Canvas.Left="454"
                            Canvas.Top="0" />

                    <Grid Width="479"
                          Height="30"
                          Canvas.Left="0"
                          Canvas.Top="5">
                        <Label Content="Definições"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{DynamicResource menuFont}"
                               FontSize="13.5"
                               Foreground="{DynamicResource highLight}" />
                    </Grid>

                    <Label Content="Base de dados"
                           Canvas.Left="16"
                           Canvas.Top="46"
                           Style="{DynamicResource formLabel}"
                           Width="95" />
                    <TextBox Name="db_string"
                             Width="325"
                             Canvas.Left="116"
                             Canvas.Top="46"
                             Height="25"
                             HorizontalContentAlignment="Left"
                             TextAlignment="Left"
                             Style="{StaticResource descTextBox}" />
                    <Button Width="33" Height="25"
                            x:Name="btn_db_path"
                            Click="btn_db_path_Click"
                            Style="{StaticResource settingsFolderPickerButtonStyle}"
                            Canvas.Left="446"
                            Canvas.Top="46" />

                    <Label Content="Pasta de fotos"
                           Canvas.Left="16"
                           Canvas.Top="79"
                           Style="{DynamicResource formLabel}"
                           Width="95" />
                    <TextBox x:Name="img_folder"
                             IsReadOnly="True"
                             Width="325"
                             Canvas.Left="116"
                             Canvas.Top="79"
                             Height="26"
                             HorizontalAlignment="Left"
                             HorizontalContentAlignment="Left"
                             TextAlignment="Left"
                             Style="{StaticResource descTextBox}" />
                    <Button Width="33" Height="26"
                            x:Name="btn_img_folder"
                            Click="btn_img_folder_Click"
                            Style="{StaticResource settingsFolderPickerButtonStyle}"
                            Canvas.Left="446"
                            Canvas.Top="79" />

                    <Grid Width="479"
                          Height="30"
                          Canvas.Left="0"
                          Canvas.Top="126">
                        <Button x:Name="btn_save_changes"
                                Content="Guardar"
                                Click="btn_save_changes_Click"
                                Height="24"
                                Width="86"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                    </Grid>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>






