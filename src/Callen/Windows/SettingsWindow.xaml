<Window x:Class="Callen.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SettingsWindow"
        Height="520"
        Width="560"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="settingsCloseButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource dialogCloseButtonBase}" />

        <Style x:Key="settingsIconButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource dialogIconButtonBase}" />

    </Window.Resources>

    <Grid>
        <Border Name="closeBorder"
                Style="{StaticResource DialogOverlayDimmer}"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="560" Height="520">
                <Canvas Width="362"
                        Height="214"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <Border Height="214"
                            Width="362"
                            Canvas.Left="0"
                            Canvas.Top="0"
                            Style="{StaticResource dialogSurfaceBorder}" />

                    <Button Width="25" Height="25"
                            Panel.ZIndex="3"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource settingsCloseButtonStyle}"
                            Canvas.Left="335"
                            Canvas.Top="2" />

                    <Grid Width="362"
                          Height="{StaticResource dialogTitleHeight}"
                          Canvas.Left="0"
                          Canvas.Top="4">
                        <Label Content="{DynamicResource Settings.Title}"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{DynamicResource menuFont}"
                               FontSize="13.5"
                               Foreground="{DynamicResource highLight}" />
                    </Grid>

                    <Grid Width="351"
                          Height="158"
                          Canvas.Left="{StaticResource layoutMargin}"
                          Canvas.Top="46">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="233" />
                            <ColumnDefinition Width="0" />
                            <ColumnDefinition Width="26" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="26" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Content="{DynamicResource Settings.Version}"
                               Style="{DynamicResource formLabel}"
                               Width="86" />
                        <TextBlock x:Name="app_version"
                                   Grid.Row="0"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource highLight}"
                                   Cursor="Hand"
                                   TextDecorations="Underline"
                                   ToolTip="{DynamicResource Settings.ReleaseTooltip}"
                                   MouseLeftButtonUp="app_version_MouseLeftButtonUp" />
                        <Button x:Name="btn_check_updates"
                                Grid.Row="0"
                                Grid.Column="4"
                                Click="btn_check_updates_Click"
                                Width="25"
                                Height="25"
                                Tag="{StaticResource Icon.Refresh}"
                                ToolTip="{DynamicResource Settings.Update}"
                                Style="{StaticResource settingsIconButtonStyle}" />

                        <Label x:Name="lbl_language"
                               Grid.Row="2"
                               Grid.Column="0"
                               Content="{DynamicResource Settings.Language}"
                               Style="{DynamicResource formLabel}"
                               Width="86" />
                        <ComboBox x:Name="combo_language"
                                  Grid.Row="2"
                                  Grid.Column="2"
                                  Width="164"
                                  HorizontalAlignment="Left"
                                  Height="26"
                                  SelectionChanged="combo_language_SelectionChanged" />

                        <Label x:Name="lbl_database"
                               Grid.Row="4"
                               Grid.Column="0"
                               Content="{DynamicResource Settings.Database}"
                               Style="{DynamicResource formLabel}"
                               Width="86" />
                        <TextBox Name="db_string"
                                 Grid.Row="4"
                                 Grid.Column="2"
                                 Height="25"
                                 HorizontalContentAlignment="Left"
                                 TextAlignment="Left"
                                 Style="{StaticResource descTextBox}" />
                        <Button Width="25"
                                Height="25"
                                Grid.Row="4"
                                Grid.Column="4"
                                x:Name="btn_db_path"
                                Click="btn_db_path_Click"
                                Tag="{StaticResource Icon.OpenFolder}"
                                Style="{StaticResource settingsIconButtonStyle}" />

                        <Label x:Name="lbl_images"
                               Grid.Row="6"
                               Grid.Column="0"
                               Content="{DynamicResource Settings.ImagesFolder}"
                               Style="{DynamicResource formLabel}"
                               Width="86" />
                        <TextBox x:Name="img_folder"
                                 Grid.Row="6"
                                 Grid.Column="2"
                                 IsReadOnly="True"
                                 Height="25"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Left"
                                 TextAlignment="Left"
                                 Style="{StaticResource descTextBox}" />
                        <Button Width="25"
                                Height="25"
                                Grid.Row="6"
                                Grid.Column="4"
                                x:Name="btn_img_folder"
                                Click="btn_img_folder_Click"
                                Tag="{StaticResource Icon.OpenFolder}"
                                Style="{StaticResource settingsIconButtonStyle}" />

                        <Grid x:Name="save_row"
                              Grid.Row="8"
                              Grid.Column="0"
                              Grid.ColumnSpan="5"
                              Style="{StaticResource bottomActionRow}">
                        <Button x:Name="btn_save_changes"
                                Content="{DynamicResource Settings.Save}"
                                Click="btn_save_changes_Click"
                                Style="{StaticResource bottomActionButtonLast}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>






