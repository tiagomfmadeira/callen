<Window x:Class="Callen.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SettingsWindow"
        Height="520"
        Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="settingsCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.CloseWindow}"
                                           Tint="#FF2E3136"
                                           Width="{StaticResource dialogCloseIconSize}"
                                           Height="{StaticResource dialogCloseIconSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="settingsIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{TemplateBinding Tag}"
                                           Width="{StaticResource dialogIconSize}"
                                           Height="{StaticResource dialogIconSize}"
                                           Tint="#FF2E3136" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Border Name="closeBorder"
                Style="{StaticResource DialogOverlayDimmer}"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="560">
                <Canvas Width="479"
                        Height="202"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <Border Height="202" Width="479" Canvas.Left="0" Canvas.Top="0"
                            Background="{DynamicResource lightestHighLight}"
                            BorderBrush="{DynamicResource highLight}"
                            BorderThickness="1"
                            CornerRadius="3,3,3,3" />

                    <Button Width="25" Height="25"
                            Panel.ZIndex="3"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource settingsCloseButtonStyle}"
                            Canvas.Left="452"
                            Canvas.Top="2" />

                    <Grid Width="479"
                          Height="30"
                          Canvas.Left="0"
                          Canvas.Top="4">
                        <Label Content="{DynamicResource Settings.Title}"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{DynamicResource menuFont}"
                               FontSize="13.5"
                               Foreground="{DynamicResource highLight}" />
                    </Grid>

                    <Label Content="{DynamicResource Settings.Version}"
                           Canvas.Left="10"
                           Canvas.Top="36"
                           Style="{DynamicResource formLabel}"
                           Width="95" />
                    <TextBlock x:Name="app_version"
                             Width="332"
                             Canvas.Left="108"
                             Canvas.Top="42"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource highLight}"
                             Cursor="Hand"
                             TextDecorations="Underline"
                             ToolTip="{DynamicResource Settings.ReleaseTooltip}"
                             MouseLeftButtonUp="app_version_MouseLeftButtonUp" />
                    <Button x:Name="btn_check_updates"
                            Click="btn_check_updates_Click"
                            Width="25"
                            Height="25"
                            Tag="{StaticResource Icon.Refresh}"
                            ToolTip="{DynamicResource Settings.Update}"
                            Style="{StaticResource settingsIconButtonStyle}"
                            Canvas.Left="444"
                            Canvas.Top="40" />

                    <Label x:Name="lbl_language"
                           Content="{DynamicResource Settings.Language}"
                           Canvas.Left="10"
                           Canvas.Top="66"
                           Style="{DynamicResource formLabel}"
                           Width="95" />
                    <ComboBox x:Name="combo_language"
                              Width="182"
                              Canvas.Left="108"
                              Canvas.Top="66"
                              Height="26"
                              SelectionChanged="combo_language_SelectionChanged" />

                    <Label x:Name="lbl_database"
                           Content="{DynamicResource Settings.Database}"
                           Canvas.Left="10"
                           Canvas.Top="96"
                           Style="{DynamicResource formLabel}"
                           Width="95" />
                    <TextBox Name="db_string"
                             Width="332"
                             Canvas.Left="108"
                             Canvas.Top="96"
                             Height="25"
                             HorizontalContentAlignment="Left"
                             TextAlignment="Left"
                             Style="{StaticResource descTextBox}" />
                    <Button Width="25" Height="25"
                            x:Name="btn_db_path"
                            Click="btn_db_path_Click"
                            Tag="{StaticResource Icon.OpenFolder}"
                            Style="{StaticResource settingsIconButtonStyle}"
                            Canvas.Left="444"
                            Canvas.Top="96" />

                    <Label x:Name="lbl_images"
                           Content="{DynamicResource Settings.ImagesFolder}"
                           Canvas.Left="10"
                           Canvas.Top="126"
                           Style="{DynamicResource formLabel}"
                           Width="95" />
                    <TextBox x:Name="img_folder"
                             IsReadOnly="True"
                             Width="332"
                             Canvas.Left="108"
                             Canvas.Top="126"
                             Height="25"
                             HorizontalAlignment="Left"
                             HorizontalContentAlignment="Left"
                             TextAlignment="Left"
                             Style="{StaticResource descTextBox}" />
                    <Button Width="25" Height="25"
                            x:Name="btn_img_folder"
                            Click="btn_img_folder_Click"
                            Tag="{StaticResource Icon.OpenFolder}"
                            Style="{StaticResource settingsIconButtonStyle}"
                            Canvas.Left="444"
                            Canvas.Top="126" />

                    <Grid x:Name="save_row"
                          Width="479"
                          Canvas.Left="0"
                          Canvas.Top="163"
                          Style="{StaticResource bottomActionRow}">
                        <Button x:Name="btn_save_changes"
                                Content="{DynamicResource Settings.Save}"
                                Click="btn_save_changes_Click"
                                Style="{StaticResource bottomActionButtonLast}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                    </Grid>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>






