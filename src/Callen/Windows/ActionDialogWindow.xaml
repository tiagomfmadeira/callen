<Window x:Class="Callen.Windows.ActionDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialog"
        Width="460"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Style="{StaticResource dialogSurfaceBorder}"
            Padding="{StaticResource layoutMarginThickness}">
        <StackPanel HorizontalAlignment="Center">
            <Grid Width="400"
                  HorizontalAlignment="Center">
                <TextBlock Name="dialogTitle"
                           Margin="0,0,0,6"
                           FontWeight="ExtraBlack"
                           FontSize="16"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="392" />
            </Grid>
            <TextBlock Name="dialogContext"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="392"
                       Visibility="Collapsed" />
            <TextBlock Name="dialogMessage"
                       Margin="0,0,0,10"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="392" />

            <StackPanel Orientation="Horizontal"
                        Style="{StaticResource bottomActionRow}">
                <Button Name="btn_cancel"
                        Style="{StaticResource bottomActionButton}"
                        Click="btn_cancel_Click"
                        Visibility="Collapsed" />
                <Button Name="btn_secondary"
                        Style="{StaticResource bottomActionButton}"
                        Click="btn_secondary_Click"
                        Visibility="Collapsed" />
                <Button Name="btn_primary"
                        Style="{StaticResource bottomActionButtonLast}"
                        Click="btn_primary_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

