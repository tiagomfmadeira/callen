<Window x:Class="Callen.Windows.Forms.SplitArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SplitArchiveWindow"
        Height="600"
        Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="dialogCloseButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource dialogCloseButtonBase}" />
    </Window.Resources>

    <Grid>
        <Border Name="closeBorder"
                Style="{StaticResource DialogOverlayDimmer}"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="600">
                <Canvas Height="214"
                        Width="430"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                    <Border Height="214"
                            Width="430"
                            Canvas.Left="0"
                            Canvas.Top="0"
                            Style="{StaticResource dialogSurfaceBorder}" />

                    <Button Width="25" Height="25"
                            Panel.ZIndex="3"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource dialogCloseButtonStyle}"
                            Canvas.Left="403"
                            Canvas.Top="2" />

                    <Grid Width="430"
                          Height="{StaticResource dialogTitleHeight}"
                          Canvas.Left="0"
                          Canvas.Top="4"
                          Panel.ZIndex="2">
                        <Label Name="wind_name"
                               Content="{DynamicResource ManageArchive.SplitTitle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Style="{DynamicResource menuFont}"
                               FontSize="13.5"
                               Foreground="{DynamicResource highLight}" />
                    </Grid>

                    <Grid Width="410"
                          Height="158"
                          Canvas.Left="{StaticResource layoutMargin}"
                          Canvas.Top="46">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="284" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="24" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Content="{DynamicResource ManageArchive.SplitSourceFolder}"
                               Style="{DynamicResource formLabel}"
                               Width="120" />
                        <TextBox Name="source_folder_box"
                                 Grid.Row="0"
                                 Grid.Column="2"
                                 Width="284"
                                 Height="26"
                                 IsEnabled="False"
                                 TextAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Style="{DynamicResource formTextBox}" />

                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Content="{DynamicResource ManageArchive.SplitPoint}"
                               Style="{DynamicResource formLabel}"
                               Width="120" />

                        <Grid Grid.Row="2"
                              Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <TextBox Name="bound_start_box"
                                     Grid.Column="0"
                                     Height="26"
                                     HorizontalAlignment="Stretch"
                                     TextAlignment="Center"
                                     Style="{DynamicResource formTextBox}"
                                     TextChanged="bound_box_TextChanged" />
                            <Border Grid.Column="1"
                                    Height="1"
                                    VerticalAlignment="Center"
                                    Margin="2,0,2,0"
                                    Background="{DynamicResource highLight}" />
                            <TextBox Name="bound_middle_box"
                                     Grid.Column="2"
                                     Height="26"
                                     HorizontalAlignment="Stretch"
                                     TextAlignment="Center"
                                     Style="{DynamicResource formTextBox}"
                                     TextChanged="bound_box_TextChanged" />
                            <Border Grid.Column="3"
                                    Height="1"
                                    VerticalAlignment="Center"
                                    Margin="2,0,2,0"
                                    Background="{DynamicResource highLight}" />
                            <TextBox Name="bound_end_box"
                                     Grid.Column="4"
                                     Height="26"
                                     HorizontalAlignment="Stretch"
                                     TextAlignment="Center"
                                     Style="{DynamicResource formTextBox}"
                                     TextChanged="bound_box_TextChanged" />
                        </Grid>

                        <Label Grid.Row="4"
                               Grid.Column="0"
                               Content="{DynamicResource ManageArchive.SplitTargetOneCode}"
                               Style="{DynamicResource formLabel}"
                               Width="120" />
                        <Grid Grid.Row="4"
                              Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <TextBox Name="target_code_a_box"
                                     Grid.Column="0"
                                     Height="26"
                                     HorizontalAlignment="Stretch"
                                     TextAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     Style="{DynamicResource formTextBox}" />
                            <Border Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Width="86"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Background="#FFE1E3E5"
                                    BorderBrush="{DynamicResource highLight}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <TextBlock Name="target_range_a_tag"
                                           Foreground="#FF6B7077"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           FontSize="12.5" />
                            </Border>
                        </Grid>

                        <Label Grid.Row="6"
                               Grid.Column="0"
                               Content="{DynamicResource ManageArchive.SplitTargetTwoCode}"
                               Style="{DynamicResource formLabel}"
                               Width="120" />
                        <Grid Grid.Row="6"
                              Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <TextBox Name="target_code_b_box"
                                     Grid.Column="0"
                                     Height="26"
                                     HorizontalAlignment="Stretch"
                                     TextAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     Style="{DynamicResource formTextBox}" />
                            <Border Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Width="86"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Background="#FFE1E3E5"
                                    BorderBrush="{DynamicResource highLight}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <TextBlock Name="target_range_b_tag"
                                           Foreground="#FF6B7077"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           FontSize="12.5" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="8"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Height="24"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0">
                            <Button Name="btn_split"
                                    Click="btn_split_Click"
                                    Content="{DynamicResource ManageArchive.SplitConfirm}"
                                    Style="{StaticResource bottomActionButtonLast}"
                                    Height="24"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
