<Window x:Class="Callen.Windows.Forms.AddItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Name="w1"
        Title="AddItemWindow"
        Height="600"
        Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="dialogCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.CloseWindow}"
                                           Tint="#FF2E3136"
                                           Width="{StaticResource dialogCloseIconSize}"
                                           Height="{StaticResource dialogCloseIconSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="dialogIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{TemplateBinding Tag}"
                                           Width="{StaticResource dialogIconSize}"
                                           Height="{StaticResource dialogIconSize}"
                                           Tint="#FF2E3136"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#59000000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Name="closeBorder"
                Style="{StaticResource DialogOverlayDimmer}"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="600">
                <Grid x:Name="sceneRoot"
                      Width="560"
                      Height="470"
                      ClipToBounds="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Canvas Width="560"
                            Height="470"
                            ClipToBounds="False">
                        <Border Name="img_border"
                                Width="150"
                                Height="120"
                                Canvas.Left="205"
                                Canvas.Top="0"
                                Background="#FFD7D9DB"
                                BorderBrush="#FF2E3136"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Image Name="img"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <Button x:Name="btn_upload"
                                        Click="btn_upload_Click"
                                        Width="150"
                                        Height="120"
                                        Tag="{StaticResource Icon.Upload}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Style="{StaticResource imageUploadOverlayButton}">
                                    <ui:TintedIcon MaskSource="{StaticResource Icon.Upload}"
                                                   Width="{StaticResource dialogIconSize}"
                                                   Height="{StaticResource dialogIconSize}"
                                                   Tint="#FF2E3136" />
                                </Button>
                            </Grid>
                        </Border>

                        <Canvas Width="560"
                                Height="340"
                                Canvas.Left="0"
                                Canvas.Top="125">
                            <Border Height="340"
                                    Width="560"
                                    Background="{DynamicResource lightestHighLight}"
                                    BorderBrush="{DynamicResource highLight}"
                                    BorderThickness="1"
                                    CornerRadius="3,3,3,3" />

                            <Button Width="25"
                                    Height="25"
                                    Panel.ZIndex="3"
                                    x:Name="btn_close"
                                    Click="btn_close_Click"
                                    Style="{StaticResource dialogCloseButtonStyle}"
                                    Canvas.Left="533"
                                    Canvas.Top="2" />

                            <Label Content="{DynamicResource AddItem.Name}"
                                   Canvas.Left="12"
                                   Canvas.Top="36"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <TextBox Name="name_box"
                                     Width="185"
                                     Canvas.Left="95"
                                     Canvas.Top="36"
                                     Height="26"
                                     Style="{DynamicResource formTextBox}" />

                            <Label Content="{DynamicResource AddItem.Folder}"
                                   Canvas.Left="292"
                                   Canvas.Top="36"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <ComboBox Name="combo_folder"
                                      Width="157"
                                      Canvas.Left="375"
                                      Canvas.Top="36"
                                      Height="26"
                                      SelectionChanged="combo_folder_SelectionChanged" />

                            <Button Name="btn_manage_archive"
                                    Click="btn_manage_archive_Click"
                                    Tag="{StaticResource Icon.Archive}"
                                    Width="25"
                                    Height="25"
                                    Canvas.Top="36"
                                    Canvas.Left="533"
                                    Style="{StaticResource dialogIconButtonStyle}" />

                            <Label Content="{DynamicResource AddItem.Year}"
                                   Canvas.Left="12"
                                   Canvas.Top="72"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <TextBox Name="year_box"
                                     Width="185"
                                     Canvas.Left="95"
                                     Canvas.Top="72"
                                     Height="26"
                                     Style="{DynamicResource formTextBox}" />

                            <Label Content="{DynamicResource AddItem.Theme}"
                                   Canvas.Left="292"
                                   Canvas.Top="72"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <ComboBox Name="combo_theme"
                                      Width="157"
                                      Canvas.Left="375"
                                      Canvas.Top="72"
                                      Height="26"
                                      IsEnabled="False" />

                            <Label Content="{DynamicResource AddItem.Collection}"
                                   Canvas.Left="12"
                                   Canvas.Top="108"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <TextBox Name="collec_box"
                                     Width="185"
                                     Canvas.Left="95"
                                     Canvas.Top="108"
                                     Height="26"
                                     Style="{DynamicResource formTextBox}" />

                            <Label Content="{DynamicResource AddItem.Matrix}"
                                   Canvas.Left="292"
                                   Canvas.Top="108"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <TextBox Name="other_box"
                                     Width="173"
                                     Canvas.Left="375"
                                     Canvas.Top="108"
                                     Height="26"
                                     Style="{DynamicResource formTextBox}" />

                            <Label Content="{DynamicResource AddItem.Description}"
                                   Canvas.Left="12"
                                   Canvas.Top="144"
                                   Style="{DynamicResource formLabel}"
                                   Width="77"
                                   Height="26" />
                            <TextBox Name="desc_box"
                                     Width="536"
                                     Canvas.Left="12"
                                     Canvas.Top="174"
                                     Height="120"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Style="{DynamicResource formTextBox}" />

                            <Grid Width="560"
                                  Canvas.Left="0"
                                  Canvas.Top="304"
                                  Style="{StaticResource bottomActionRow}">
                                <Button Name="btn_insert"
                                        Click="btn_insert_Click"
                                        Content="{DynamicResource AddItem.Insert}"
                                        Style="{StaticResource bottomActionButtonLast}" />
                            </Grid>
                        </Canvas>
                    </Canvas>
                </Grid>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
