<Window x:Class="Callen.Windows.ItemDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:componentModel="clr-namespace:System.ComponentModel;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:Callen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ItemDetailsWindow"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="{x:Null}"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="TooltipBubbleStyle" TargetType="{x:Type Border}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="CornerRadius" Value="7,7,0,7" />
            <Setter Property="Background" Value="{DynamicResource lightHighLight}" />
            <Setter Property="BorderBrush" Value="{DynamicResource highLight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Panel.ZIndex" Value="30" />
            <Setter Property="Padding" Value="6,2,6,2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(componentModel:DesignerProperties.IsInDesignMode)}"
                             Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DescLabel" TargetType="{x:Type Label}" BasedOn="{StaticResource formLabel}">
            <Setter Property="Width" Value="65"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarActionButton" TargetType="{x:Type Button}" BasedOn="{StaticResource dialogIconButtonBase}">
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DescCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource dialogCloseButtonBase}" />

        <Style x:Key="DescNavPrevButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="{DynamicResource lightestHighLight}"
                                BorderBrush="{DynamicResource highLight}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.PreviousPage}"
                                           Width="{StaticResource dialogIconSize}"
                                           Height="{StaticResource dialogIconSize}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Tint="#FF2E3136"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource lightHighLight}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource highLight}" />
                                <Setter TargetName="img" Property="Tint" Value="{DynamicResource lightestHighLight}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DescNavNextButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource menuMinButton}">
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                Background="{DynamicResource lightestHighLight}"
                                BorderBrush="{DynamicResource highLight}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ui:TintedIcon x:Name="img"
                                           MaskSource="{StaticResource Icon.NextPage}"
                                           Width="{StaticResource dialogIconSize}"
                                           Height="{StaticResource dialogIconSize}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Tint="#FF2E3136"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource lightHighLight}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource highLight}" />
                                <Setter TargetName="img" Property="Tint" Value="{DynamicResource lightestHighLight}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Full-window overlay -->
        <Border Name="closeBorder"
                Style="{StaticResource DialogOverlayDimmer}"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="600">
                <Grid x:Name="sceneRoot"
                      Width="590"
                      Height="436"
                      ClipToBounds="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Canvas x:Name="overlayCanvas"
                            ClipToBounds="False"
                            Panel.ZIndex="10">
                <!--#region Image Preview-->
                    <Border CornerRadius="3,3,3,3"
                        Background="{DynamicResource lightestHighLight}"
                        Name="img_border"
                        Panel.ZIndex="20"
                        Height="120"
                        Width="150"
                        Canvas.Left="216"
                        Canvas.Top="0"
                        Visibility="Hidden"
                        ClipToBounds="True"
                        Style="{StaticResource simpleBorder}">
                        <Grid>
                            <Button Name="btn_img"
                                Click="btn_img_Click"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Height="120"
                                Width="150"
                                BorderBrush="{x:Null}">
                                <!-- Aspect ratio preserved; fills the box without deformation -->
                                <Image Name="img"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Name="border"
                                                        BorderThickness="0,0,0,0"
                                                        BorderBrush="{DynamicResource foreground}"
                                                        Background="{x:Null}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Cursor" Value="Hand" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                    <Button Width="150" Height="120" Panel.ZIndex="21"
                        x:Name="btn_upload_image"
                        Click="btn_upload_image_Click"
                        Canvas.Left="0" Canvas.Top="0"
                        Style="{StaticResource imageUploadOverlayButton}"
                        Visibility="Hidden">
                        <ui:TintedIcon MaskSource="{StaticResource Icon.Upload}"
                                       Width="{StaticResource dialogIconSize}"
                                       Height="{StaticResource dialogIconSize}"
                                       Tint="#FF2E3136" />
                    </Button>
                    <!--#endregion-->

                    <!--#region Tooltip-->
                    <Border x:Name="pop_save"
                        Style="{StaticResource TooltipBubbleStyle}"
                        Canvas.Left="627"
                        Canvas.Top="121">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="pop_save_translate" Y="6" />
                        </Border.RenderTransform>
                        <TextBlock
                               VerticalAlignment="Center"
                               Text="{DynamicResource Details.TooltipSave}"
                               TextWrapping="WrapWithOverflow" />
                    </Border>

                    <Border x:Name="pop_edit"
                        Style="{StaticResource TooltipBubbleStyle}"
                        Canvas.Left="631"
                        Canvas.Top="94">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="pop_edit_translate" Y="6" />
                        </Border.RenderTransform>
                        <TextBlock
                               VerticalAlignment="Center"
                               Text="{DynamicResource Details.TooltipEdit}"
                               TextWrapping="WrapWithOverflow" />
                    </Border>

                    <Border x:Name="pop_dup"
                        Style="{StaticResource TooltipBubbleStyle}"
                        Canvas.Left="617"
                        Canvas.Top="67">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="pop_dup_translate" Y="6" />
                        </Border.RenderTransform>
                        <TextBlock
                               VerticalAlignment="Center"
                               Text="{DynamicResource Details.TooltipDuplicate}"
                               TextWrapping="WrapWithOverflow" />
                    </Border>

                    <Border x:Name="pop_delete"
                        Style="{StaticResource TooltipBubbleStyle}"
                        Canvas.Left="617"
                        Canvas.Top="40">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="pop_delete_translate" Y="6" />
                        </Border.RenderTransform>
                        <TextBlock
                               VerticalAlignment="Center"
                               Text="{DynamicResource Details.TooltipDelete}"
                               TextWrapping="WrapWithOverflow" />
                    </Border>

                    <Border x:Name="pop_print"
                        Style="{StaticResource TooltipBubbleStyle}"
                        MaxWidth="150"
                        Canvas.Left="555"
                        Canvas.Top="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="pop_print_translate" Y="6" />
                        </Border.RenderTransform>
                        <TextBlock
                               VerticalAlignment="Center"
                               Text="{DynamicResource Details.TooltipPrint}"
                               TextWrapping="Wrap" />
                    </Border>
                    <!--#endregion-->

                    <!--#region Buttons-->
                    <Button Width="50" Height="65" Panel.ZIndex="3"
                        x:Name="btn_prev_item"
                        Click="btn_prev_item_Click"
                        Canvas.Left="0" Canvas.Top="265"
                        Style="{StaticResource DescNavPrevButtonStyle}" />

                    <Button Width="50" Height="65" Panel.ZIndex="3"
                        x:Name="btn_next_item"
                        Click="btn_next_item_Click"
                        Canvas.Left="540" Canvas.Top="265"
                        Style="{StaticResource DescNavNextButtonStyle}" />
                    <!--#endregion-->
                    </Canvas>

                    <!--#region Data-->
                    <Canvas x:Name="detailsCard"
                        Width="480"
                        Height="317"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Panel.ZIndex="1"
                        IsHitTestVisible="True">
                        <Border Height="317"
                            Width="480"
                            Style="{StaticResource dialogSurfaceBorder}" />

                        <Button Width="25" Height="25" Panel.ZIndex="1"
                            x:Name="btn_save"
                            Click="btn_save_Click"
                            IsEnabled="False"
                            MouseEnter="btn_save_MouseEnter"
                            MouseLeave="btn_save_MouseLeave"
                            Tag="{StaticResource Icon.Save}"
                            Style="{StaticResource ToolbarActionButton}"
                            Canvas.Left="318" Canvas.Top="2" />

                        <Button Width="25" Height="25" Panel.ZIndex="1"
                            x:Name="btn_edit"
                            Click="btn_edit_Click"
                            MouseEnter="btn_edit_MouseEnter"
                            MouseLeave="btn_edit_MouseLeave"
                            Tag="{StaticResource Icon.Edit}"
                            Style="{StaticResource ToolbarActionButton}"
                            Canvas.Left="345" Canvas.Top="2" />

                        <Button Width="25" Height="25" Panel.ZIndex="1"
                            x:Name="btn_duplicate"
                            Click="btn_duplicate_Click"
                            MouseEnter="btn_duplicate_MouseEnter"
                            MouseLeave="btn_duplicate_MouseLeave"
                            Tag="{StaticResource Icon.Duplicate}"
                            Style="{StaticResource ToolbarActionButton}"
                            Canvas.Left="372" Canvas.Top="2" />

                        <Button Width="25" Height="25" Panel.ZIndex="1"
                            x:Name="btn_delete"
                            Click="btn_delete_Click"
                            MouseEnter="btn_delete_MouseEnter"
                            MouseLeave="btn_delete_MouseLeave"
                            Tag="{StaticResource Icon.Delete}"
                            Style="{StaticResource ToolbarActionButton}"
                            Canvas.Left="399" Canvas.Top="2" />

                        <Button Width="25" Height="25" Panel.ZIndex="1"
                            x:Name="btn_print"
                            Click="btn_print_Click"
                            MouseEnter="btn_print_MouseEnter"
                            MouseLeave="btn_print_MouseLeave"
                            Tag="{StaticResource Icon.Print}"
                            Style="{StaticResource ToolbarActionButton}"
                            Canvas.Left="426" Canvas.Top="2" />

                        <Button Width="25" Height="25" Panel.ZIndex="3"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource DescCloseButtonStyle}"
                            Canvas.Left="453" Canvas.Top="2" />

                        <TextBox Name="item_name"
                             IsEnabled="False"
                             Width="460"
                             Canvas.Left="10"
                             Canvas.Top="27"
                             Height="40"
                             FontWeight="Bold"
                             FontSize="13.5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Style="{StaticResource descTextBox}" />

                        <TextBox Name="item_year"
                             IsEnabled="False"
                             Width="120"
                             Canvas.Left="180"
                             Canvas.Top="70"
                             Height="26"
                             FontWeight="Bold"
                             FontSize="13.8"
                             Style="{StaticResource descTextBox}" />

                        <Label Content="{DynamicResource Details.Collection}" Canvas.Left="10" Canvas.Top="111" Style="{StaticResource DescLabel}" />
                        <TextBox Name="item_collec" IsEnabled="False" Width="157" Canvas.Left="81" Canvas.Top="111" Height="26" Style="{StaticResource descTextBox}" />

                        <Label Content="{DynamicResource Details.Matrix}" Canvas.Left="10" Canvas.Top="146" Style="{StaticResource DescLabel}" />
                        <TextBox Name="item_other" IsEnabled="False" Width="157" Canvas.Left="81" Canvas.Top="146" Height="26" Style="{StaticResource descTextBox}" />

                        <Label Content="{DynamicResource Details.Description}" Canvas.Left="10" Canvas.Top="181" Style="{StaticResource DescLabel}" />
                        <TextBox Name="item_desc"
                             IsEnabled="False"
                             VerticalContentAlignment="Center"
                             Width="460"
                             Canvas.Left="10"
                             Canvas.Top="207"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Style="{StaticResource descTextBox}" />

                        <Label Content="{DynamicResource Details.Folder}" Canvas.Left="248" Canvas.Top="111" Style="{StaticResource DescLabel}"/>
                        <TextBox Name="item_folder" IsEnabled="False" Width="133" Canvas.Left="319" Canvas.Top="111" Height="26" Style="{StaticResource descTextBox}" />
                        <ComboBox Name="combo_folder"
                              Visibility="Hidden"
                              Width="133"
                              Canvas.Left="319"
                              Canvas.Top="111"
                              Padding="0,2,22,2"
                              Height="26"
                              SelectionChanged="combo_folder_SelectionChanged" />

                        <Button Name="btn_manage_archive"
                            Click="btn_manage_archive_Click"
                            IsEnabled="False"
                            Tag="{StaticResource Icon.Archive}"
                            Width="25"
                            Height="25"
                            Canvas.Top="112"
                            Canvas.Left="453"
                            Style="{StaticResource ToolbarActionButton}" />

                        <Label Content="{DynamicResource Details.Theme}" Canvas.Left="248" Canvas.Top="146" Style="{StaticResource DescLabel}"/>
                        <TextBox Name="item_theme" IsEnabled="False" Width="133" Canvas.Left="319" Canvas.Top="146" Height="26" Style="{StaticResource descTextBox}" />

                        <ComboBox Name="combo_theme"
                              Visibility="Hidden"
                              Width="133"
                              Canvas.Left="319"
                              Canvas.Top="146"
                              Padding="0,2,22,2"
                              Height="26" />
                    </Canvas>
                    <!--#endregion-->
                </Grid>

            </Grid>
        </Viewbox>
    </Grid>
</Window>









