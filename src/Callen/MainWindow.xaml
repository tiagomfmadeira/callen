<Window x:Class="Callen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Callen"
        xmlns:pages="clr-namespace:Callen.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Collection Manager"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="600" Width="800" WindowState="Normal"
        Background="{x:Null}" Icon="{StaticResource Icon.Logo}">
    <Window.Resources>
        <Style x:Key="sidebarMenuButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource menuButton}">
            <Setter Property="Width" Value="55" />
            <Setter Property="Height" Value="65" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border Name="border"
                                BorderThickness="0,0,0,0"
                                BorderBrush="{x:Null}"
                                Background="{x:Null}">
                            <ui:TintedIcon x:Name="menuIcon"
                                           MaskSource="{TemplateBinding Tag}"
                                           Width="31"
                                           Height="31"
                                           Tint="#FF787878"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter TargetName="menuIcon" Property="Tint" Value="#FFC9CBCC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="menuIcon" Property="Tint" Value="#FFC9CBCC" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#121516" />
                                <Setter TargetName="border" Property="BorderBrush" Value="White" />
                                <Setter TargetName="menuIcon" Property="Tint" Value="#FFC9CBCC" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="menuIcon" Property="Tint" Value="#FFFFFFFF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="sidebarActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="55" />
            <Setter Property="Height" Value="65" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border"
                                BorderThickness="0,0,0,0"
                                BorderBrush="{x:Null}"
                                Background="{x:Null}">
                            <ui:TintedIcon x:Name="actionIcon"
                                           MaskSource="{TemplateBinding Tag}"
                                           Width="31"
                                           Height="31"
                                           Tint="#FF787878"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter TargetName="actionIcon" Property="Tint" Value="#FFC9CBCC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="actionIcon" Property="Tint" Value="#FFC9CBCC" />
                            </Trigger>
                            <Trigger Property="Foreground" Value="White">
                                <Setter TargetName="actionIcon" Property="Tint" Value="#FFC9CBCC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="sidebarMenuContentStyle" TargetType="DockPanel">
            <Setter Property="Width" Value="55" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="LastChildFill" Value="True" />
        </Style>

        <Style x:Key="sidebarMenuLabelStyle" TargetType="Label" BasedOn="{StaticResource menuFont}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="topBarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource windowActionButton}" />

        <Style x:Key="topBarTintIconStyle" TargetType="{x:Type ui:TintedIcon}">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Tint" Value="#FFFFFFFF" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource mainColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55" />
            <ColumnDefinition Width="0" x:Name="grid_menu_col" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Menu Min Bar -->
        <ContentControl Grid.Column="2" MouseDoubleClick="ContentControl_MouseDoubleClick">
            <Grid Background="{DynamicResource mainColor}"
                  x:Name="menu_min_bar"
                  MouseDown="menu_min_bar_MouseDown"
                  MouseMove="menu_min_bar_MouseMove"
                  MouseLeftButtonUp="menu_min_bar_MouseLeftButtonUp">
                <Grid HorizontalAlignment="Right"
                      VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="36"
                            Height="36"
                            x:Name="btn_mini"
                            Click="btn_mini_Click"
                            Style="{StaticResource topBarActionButtonStyle}">
                        <ui:TintedIcon MaskSource="{StaticResource Icon.Minimize}"
                                       Style="{StaticResource topBarTintIconStyle}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                    </Button>

                    <Button Grid.Column="1"
                            Width="36"
                            Height="36"
                            x:Name="btn_expand"
                            Click="btn_expand_Click"
                            Style="{StaticResource topBarActionButtonStyle}">
                        <ui:TintedIcon MaskSource="{StaticResource Icon.Expand}"
                                       Style="{StaticResource topBarTintIconStyle}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                    </Button>

                    <Button Grid.Column="2"
                            Width="36"
                            Height="36"
                            x:Name="btn_close"
                            Click="btn_close_Click"
                            Style="{StaticResource topBarActionButtonStyle}">
                        <ui:TintedIcon MaskSource="{StaticResource Icon.CloseWindow}"
                                       Style="{StaticResource topBarTintIconStyle}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                    </Button>
                </Grid>
            </Grid>
        </ContentControl>
        <!-- Content Frame -->
        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
            <Grid x:Name="Content_plane">
                <pages:Search Visibility="Collapsed"
                              IsHitTestVisible="False" />
            </Grid>
        </Border>

        <!-- Menu Bar Items -->
        <Border Grid.RowSpan="2" Grid.ColumnSpan="2" Name="menu_border" Background="{DynamicResource darkestHighLight}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel HorizontalAlignment="Left">
                    <ToggleButton Style="{StaticResource sidebarMenuButtonStyle}"
                                  x:Name="btn_colec"
                                  Tag="{StaticResource Icon.Collection}"
                                  Click="btn_colec_Click" />
                    <Button Style="{StaticResource sidebarActionButtonStyle}"
                            x:Name="btn_add_item"
                            Tag="{StaticResource Icon.Plus}"
                            Click="btn_add_item_Click">
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource sidebarActionButtonStyle}"
                            x:Name="btn_print"
                            Tag="{StaticResource Icon.Print}"
                            Click="btn_print_Click">
                    </Button>
                    <Button Style="{StaticResource sidebarActionButtonStyle}"
                            x:Name="btn_settings"
                            Tag="{StaticResource Icon.Settings}"
                            Click="btn_settings_Click">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


